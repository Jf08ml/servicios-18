# Variables de producción — en Dokploy se pegan en Environment del servicio Compose.
# NUNCA subas el archivo real al repositorio.

# Contraseña del Postgres interno (genera una: openssl rand -hex 24)
POSTGRES_PASSWORD=""

# Dominio de producción, sin barra final (canonicals, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://tudominio.com"

# Web Push (VAPID). Genera un par NUEVO para producción:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:lassojuanfe@gmail.com"
