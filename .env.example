# Postgres del docker-compose.yml (puerto 5434). Si usas tu propio Postgres, ajusta credenciales y puerto.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/servicios18?schema=public"

# Web Push (VAPID). Genera un par con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-correo@ejemplo.com"
