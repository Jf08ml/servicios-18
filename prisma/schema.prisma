generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WORKER
  CLIENT
  HOTEL
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReportCategory {
  PERFIL_FALSO
  ESTAFA
  ACOSO
  SEGURIDAD
  OTRO
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum SosStatus {
  ACTIVE
  RESOLVED
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum VerificationLevel {
  QUICK // foto sosteniendo cartel "Mis Escorts" + fecha
  FULL // documento + selfie (se exige ante reportes/sospechas)
}

enum NotificationType {
  APPOINTMENT
  BOOKING
  VERIFICATION
  REVIEW
  REPORT
  SOS
  SYSTEM
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role
  status       UserStatus @default(ACTIVE)
  displayName  String
  phone        String?
  birthDate    DateTime
  verifiedAt   DateTime?
  premiumUntil DateTime?
  // El admin exige la verificación completa (documento + selfie) ante reportes.
  fullVerificationRequired Boolean @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions              Session[]
  profile               Profile?
  verification          Verification?
  reviewedVerifications Verification[]     @relation("VerificationReviewer")
  emergencyContacts     EmergencyContact[]
  availability          AvailabilitySlot[]
  workerAppointments    Appointment[]      @relation("WorkerAppointments")
  clientAppointments    Appointment[]      @relation("ClientAppointments")
  conversationsA        Conversation[]     @relation("ConvA")
  conversationsB        Conversation[]     @relation("ConvB")
  messages              Message[]
  hotelBookings         HotelBooking[]
  reviewsGiven          Review[]           @relation("ReviewAuthor")
  reviewsReceived       Review[]           @relation("ReviewTarget")
  reportsMade           Report[]           @relation("Reporter")
  reportsReceived       Report[]           @relation("Reported")
  sosAlerts             SosAlert[]
  ownedHotels           Hotel[]
  mediaItems            MediaItem[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  serviceTypes          ServiceType[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  // Ubicación estructurada (códigos ISO de country-state-city + nombres denormalizados)
  countryCode String?
  countryName String?
  stateCode   String?
  stateName   String?
  city        String?
  photoPath String?
  languages String?
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([countryCode, stateCode, city])
}

model Verification {
  id                 String             @id @default(cuid())
  userId             String             @unique
  level              VerificationLevel  @default(FULL)
  // QUICK: solo selfiePath (foto con cartel). FULL: documento + selfie.
  fullName           String?
  docType            String?
  docNumber          String?
  docImagePath       String?
  selfiePath         String
  isPremiumRequested Boolean            @default(false)
  status             VerificationStatus @default(PENDING)
  notes              String?
  reviewedById       String?
  submittedAt        DateTime           @default(now())
  reviewedAt         DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("VerificationReviewer", fields: [reviewedById], references: [id])

  @@index([status])
}

model EmergencyContact {
  id     String @id @default(cuid())
  userId String
  name   String
  phone  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AvailabilitySlot {
  id          String @id @default(cuid())
  workerId    String
  weekday     Int // 0 = domingo ... 6 = sábado
  startMinute Int
  endMinute   Int

  worker User @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

// Tipos de servicio que ofrece una profesional (nombre propio + duración),
// p. ej. "El rato (15 min)" o "Amanecida (12 h)". Si no define ninguno, el
// formulario de citas ofrece duraciones estándar.
model ServiceType {
  id              String   @id @default(cuid())
  workerId        String
  name            String
  durationMinutes Int
  createdAt       DateTime @default(now())

  worker User @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model Appointment {
  id        String            @id @default(cuid())
  workerId  String
  clientId  String
  startsAt  DateTime
  endsAt    DateTime
  status    AppointmentStatus @default(PENDING)
  // Nombre del tipo de servicio elegido al agendar (copia, por si se borra el tipo).
  serviceName String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  worker       User          @relation("WorkerAppointments", fields: [workerId], references: [id], onDelete: Cascade)
  client       User          @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  hotelBooking HotelBooking?
  reviews      Review[]

  @@index([workerId, startsAt])
  @@index([clientId, startsAt])
}

model Conversation {
  id            String   @id @default(cuid())
  aId           String
  bId           String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  a        User      @relation("ConvA", fields: [aId], references: [id], onDelete: Cascade)
  b        User      @relation("ConvB", fields: [bId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([aId, bId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Hotel {
  id            String  @id @default(cuid())
  ownerId       String?
  name          String
  city          String
  address       String
  description   String?
  photoPath     String?
  commissionPct Int     @default(10)
  active        Boolean @default(true)

  owner     User?          @relation(fields: [ownerId], references: [id])
  roomTypes RoomType[]
  bookings  HotelBooking[]
}

model RoomType {
  id          String  @id @default(cuid())
  hotelId     String
  name        String
  description String?
  blockHours  Int
  price       Int
  totalRooms  Int

  hotel    Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings HotelBooking[]
}

model HotelBooking {
  id               String        @id @default(cuid())
  code             String        @unique
  hotelId          String
  roomTypeId       String
  userId           String
  appointmentId    String?       @unique
  startsAt         DateTime
  endsAt           DateTime
  status           BookingStatus @default(CONFIRMED)
  totalPrice       Int
  commissionAmount Int
  createdAt        DateTime      @default(now())

  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType    RoomType     @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([hotelId, startsAt])
  @@index([userId])
}

model Review {
  id            String   @id @default(cuid())
  appointmentId String
  authorId      String
  targetId      String
  score         Int
  comment       String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  author      User        @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target      User        @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, authorId])
  @@index([targetId])
}

model Report {
  id          String         @id @default(cuid())
  reporterId  String
  reportedId  String?
  category    ReportCategory
  description String
  status      ReportStatus   @default(OPEN)
  adminNotes  String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User? @relation("Reported", fields: [reportedId], references: [id])

  @@index([status])
}

model MediaItem {
  id        String    @id @default(cuid())
  userId    String
  kind      MediaKind
  filePath  String
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String? // ruta interna, p. ej. /citas/xyz
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SosAlert {
  id         String    @id @default(cuid())
  userId     String
  latitude   Float?
  longitude  Float?
  message    String?
  status     SosStatus @default(ACTIVE)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}
